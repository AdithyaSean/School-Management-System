@startuml SchoolManagementSystem

left to right direction
skinparam PackageStyle rectangle

actor "Teacher" as T
actor "Class Teacher" as CT
actor "Sectional Head" as SH
actor "Treasurer" as TR
actor "Student" as S
actor "Prefects" as SP
actor "Principal" as P
actor "Vice Principal" as VP
actor "Auditor" as AU
actor "Administrator" as A
actor "User" as U

U <|-- T
U <|-- S
T <|-- A
CT <|-- A
SH <|-- A
TR <|-- A
VP <|-- A
P <|-- A
S <|-- A
PS <|-- A
T <|-- CT
T <|-- SH
T <|-- TR
S <|-- SP
VP <|-- P

rectangle "School Management System" {
    U --> (Login)
    U --> (Logout)

    A --> (Login)
    A --> (Logout)

    T --> (Create and Upload Educational Content)
    T --> (Monitor Student Progress and Performance)
    T --> (Generate Student Reports)
    T --> (Provide Feedback and Assessments)
    T --> (Enter Attendance Daily)
    T --> (Submit Leave and Short Leaves)

    (Enter Attendance Daily) ..> (Verify Using Fingerprint) : <<include>>
    (Submit Leave and Short Leaves) ..> (Verify Leave) : <<include>>

    CT --> (Mark Students Attendance)
    CT --> (Collect School Fees from Students)
    CT --> (Sort Exam Results)
    CT --> (Enter Results to Student Reports)

    (Collect School Fees from Students) ..> (Update Student Records) : <<include>>
    (Sort Exam Resutls) ..> (Grade Students) : <<include>>
    (Enter Results to Student Reports) ..> (Rank Students) : <<include>>

    SH --> (Coordinate Teachers)
    SH --> (Coordinate Students)
    SH --> (Organize Events)

    (Organize Events) ..> (Evaluate Teacher Performance) : <<include>>
    
    TR --> (View School Financial Status)
    TR --> (Deposit Funds to School Account)
    TR --> (Calculate School Budget)
    TR --> (Keep Financial Records)
    TR --> (Collect School Fees from Teachers)

    (Collect School Fees from Teachers) ..> (Deposit Fees to School Account) : <<include>>

    S --> (Access and Engage with Learning Materials)
    S --> (Submit Assignments and Assessments)
    S --> (Seek Assistance from Teachers)
    S --> (Pay School Fees and Other Welfare Fees)
    S --> (Enter Attendance Daily)
    S --> (Submit Medicals for Sudden Leaves)
    S --> (Enter Extracurricular Activity Information)
    S --> (Create School Societies and Clubs)

    (Enter Attendance Daily) ..> (Verify Using Fingerprint) : <<include>>
    (Seek Assistance from Teachers) ..> (Communicate with Teachers) : <<include>>
    (Submit Medicals for Sudden Leaves) ..> (Verify Medical Information) : <<include>>
    (Create School Societies and Clubs) ..> (Add Members) : <<include>>
    (Create School Societies and Clubs) ..> (Remove Members) : <<include>>
    (Create School Societies and Clubs) ..> (Update Members) : <<include>>

    SP --> (Assist in Student Discipline)
    SP --> (Organize Student Events)

    P --> (Generate Daily Reports)
    P --> (Generate Monthly Reports)
    P --> (Generate Annual Reports)
    P --> (Organize School Events)
    P --> (Send Notifications to Teachers)

    (Generate Daily Reports) ..> (User Engagement Reports)
    (Generate Daily Reports) ..> (Performance Reports)
    (Generate Daily Reports) ..> (System Utilization Reports)
    (Generate Daily Reports) ..> (Content Popularity Reports)
    (Generate Daily Reports) ..> (Monthly Attendance Reports)

    VP --> (Assist Principal)
    VP --> (Supervise Student Enrollment)
    VP --> (Coordinate School Management)
    VP --> (Handle Administrative Tasks)

    A --> (Manage User Accounts and Access Permissions)
    A --> (Oversee Overall Functionality and Performance)
    A --> (Ensure Security and Integrity of the Platform)

    (Manage User Accounts and Access Permissions) ..> (Add User) : <<include>>
    (Manage User Accounts and Access Permissions) ..> (Delete User) : <<include>>
    (Manage User Accounts and Access Permissions) ..> (Modify Permissions) : <<include>>
    (Ensure Security and Integrity of the Platform) ..> (Encrypt Data) : <<include>>
    (Ensure Security and Integrity of the Platform) ..> (Regular Data Backups) : <<include>>
    (Conduct Staff Meetings) ..> (Inform Staff Members) : <<include>>

    (View School Financial Status) --> AU
}

@enduml