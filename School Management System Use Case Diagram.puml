@startuml School Management System

left to right direction
skinparam linetype polyline

actor "Teacher" as T
actor "Teacher" as TR
actor "Teacher" as TR2
actor "Sectional Head" as SH
actor "Sectional Head" as SHR
actor "Student" as S
actor "Student" as SR
actor "Principal" as P
actor "Principal" as PR
actor "Vice Principal" as VP
actor "Vice Principal" as VPR
actor "Administrator" as A
actor "User" as U
actor "User" as UR

U <|-- S
S <|-- T
T <|-- SH
SH <|-- VP
VP <|-- P
P <|-- A

rectangle "School Management System" {
        A -- (View User Information)
        (View User Information) <.. (Add User) : <<extend>>
        (View User Information) <.. (Update User) : <<extend>>
        (View User Information) <.. (Delete User) : <<extend>>
        (View User Information) <.. (Modify Permissions) : <<extend>>
        
        (Add User) ..> (Update Registration Records) : <<include>>
        (Update User) ..> (Update Registration Records) : <<include>>
        (Delete User) ..> (Update Registration Records) : <<include>>
        (Modify Permissions) ..> (Update Registration Records) : <<include>>

        A -- (View System Monitor)
        (View System Monitor) <.. (Generate User Engagement Reports) : <<extend>>
        (View System Monitor) <.. (Generate Performance Reports) : <<extend>>
        (View System Monitor) <.. (Generate System Utilization Reports) : <<extend>>
        (View System Monitor) <.. (Generate Content Popularity Reports) : <<extend>>
        (View System Monitor) <.. (Generate Monthly Attendance Reports) : <<extend>>
        (View System Monitor) <.. (Regular Information Backups) : <<extend>>
        
        (Generate User Engagement Reports) ..> (Inform Vice Principal) : <<include>>
        (Generate Performance Reports) ..> (Inform Vice Principal) : <<include>>
        (Generate System Utilization Reports) ..> (Inform Vice Principal) : <<include>>
        (Generate Content Popularity Reports) ..> (Inform Vice Principal) : <<include>>
        (Generate Monthly Attendance Reports) ..> (Inform Vice Principal) : <<include>>
        (Regular Information Backups) ..> (Create Logs) : <<include>>

        A -- (View System Database)
        (View System Database) <.. (Create Tables) : <<extend>>
        (View System Database) <.. (Update Tables) : <<extend>>
        (View System Database) <.. (Delete Tables) : <<extend>>

        P -- (View Administrative Information)
        (View Administrative Information) <.. (Create Policies) : <<extend>>
        (View Administrative Information) <.. (Update Policies) : <<extend>>
        (View Administrative Information) <.. (Delete Policies) : <<extend>>

        (Create Policies) ..> (Inform Sectional Heads): <<include>>
        (Update Policies) ..> (Inform Sectional Heads): <<include>>
        (Delete Policies) ..> (Inform Sectional Heads): <<include>>

        (Inform Principal) -- PR

        P -- (Broadcast Announcements)
        (Broadcast Announcements) ..> (Send Notifications) : <<include>>
        (Send Notifications) ..> (Inform Sectional Heads) : <<include>>

        VP -- (View Events Information)
        (View Events Information) <.. (Create Events) : <<extend>>
        (View Events Information) <.. (Update Events) : <<extend>>
        (View Events Information) <.. (Delete Events) : <<extend>>

        (Create Events) ..> (Inform Sectional Heads): <<include>>
        (Update Events) ..> (Inform Sectional Heads): <<include>>
        (Delete Events) ..> (Inform Sectional Heads): <<include>>

        VP -- (View Financial Information)
        (View Financial Information) <.. (Plan School Budget) : <<extend>>
        (View Financial Information) <.. (Update School Budget) : <<extend>>

        (Plan School Budget) ..> (Inform Principal): <<include>>
        (Update School Budget) ..> (Inform Principal): <<include>>
        
        (View Financial Information) <.. (Generate Financial Reports) : <<extend>>
        (View Financial Information) <.. (Withdraw Funds from School Account) : <<extend>>
        (View Financial Information) <.. (Deposit Funds to School Account) : <<extend>>

        (Generate Financial Reports) ..> (Inform Principal): <<include>>
        (Withdraw Funds from School Account) ..> (Inform Principal) : <<include>>
        (Deposit Funds to School Account) ..> (Inform Principal) : <<include>>

        (Inform Vice Principal) -- VPR
        (Update Registration Records) -- VPR

        SH -- (View Staff Information)
        (View Staff Information) <.. (Add Staff Members) : <<extend>>
        (View Staff Information) <.. (Update Staff Members) : <<extend>>
        (View Staff Information) <.. (Remove Staff Members) : <<extend>>
        (View Staff Information) <.. (Create Time Tables) : <<extend>>
        (View Staff Information) <.. (Update Time Tables) : <<extend>>
        (View Staff Information) <.. (Delete Time Tables) : <<extend>>
        (View Staff Information) <.. (Schedule Meetings) : <<extend>>

        (Add Staff Members) ..> (Inform Teachers) : <<include>>
        (Update Staff Members) ..> (Inform Teachers) : <<include>>
        (Remove Staff Members) ..> (Inform Teachers) : <<include>>
        (Create Time Tables) ..> (Inform Teachers): <<include>>
        (Update Time Tables) ..> (Inform Teachers) : <<include>>
        (Delete Time Tables) ..> (Inform Teachers) : <<include>>
        (Schedule Meetings) ..> (Inform Teachers) : <<include>>
        
        (Inform Sectional Heads) -- SHR

        T -- (View Educational Information)
        (View Educational Information) <.. (View Student Activity) : <<extend>>
        (View Educational Information) <.. (Grade Student Activity) : <<extend>>
        (View Educational Information) <.. (Send Feedback and Assessments) : <<extend>>
        (View Educational Information) <.. (Create Educational Content) : <<extend>>
        (View Educational Information) <.. (Update Educational Content) : <<extend>>
        (View Educational Information) <.. (Delete Educational Content) : <<extend>>
        (View Educational Information) <.. (View Time Table) : <<extend>>

        (Grade Student Activity) ..> (Notify Students): <<include>>
        (Send Feedback and Assessments) ..> (Notify Students): <<include>>
        (Create Educational Content) ..> (Notify Students): <<include>>
        (Update Educational Content) ..> (Notify Students): <<include>>
        (Delete Educational Content) ..> (Notify Students): <<include>>
        (View Time Table) ..> (Notify Students): <<include>>

        T -- (View Extracurricular Information)
        (View Extracurricular Information) <.. (Add Members) : <<extend>>
        (View Extracurricular Information) <.. (Remove Members) : <<extend>>
        (View Extracurricular Information) <.. (Update Members) : <<extend>>
        (View Extracurricular Information) <.. (Create Competitions) : <<extend>>
        (View Extracurricular Information) <.. (Create Societies and Clubs) : <<extend>>
        (View Extracurricular Information) <.. (Monitor Societies and Clubs) : <<extend>>
        (View Extracurricular Information) <.. (Delete Societies and Clubs) : <<extend>>
        (View Extracurricular Information) <.. (Update Societies and Clubs) : <<extend>>

        (Add Members) ..> (Notify Students): <<include>>
        (Remove Members) ..> (Notify Students): <<include>>
        (Update Members) ..> (Notify Students): <<include>>
        (Create Competitions) ..> (Notify Students): <<include>>
        (Create Societies and Clubs) ..> (Notify Students): <<include>>
        (Update Societies and Clubs) ..> (Notify Students): <<include>>

        T -- (View Students Information)
        (View Students Information) <.. (Create Student Information) : <<extend>>
        (View Students Information) <.. (Update Student Information) : <<extend>>
        (View Students Information) <.. (Delete Student Information) : <<extend>>
        (View Students Information) <.. (Generate Student Attendance Reports) : <<extend>>
        (View Students Information) <.. (Generate Student Performance Reports) : <<extend>>
        (View Students Information) <.. (Generate Enrollment Reports) : <<extend>>

        (Create Student Information) ..> (Notify Students) : <<include>>
        (Update Student Information) ..> (Notify Students) : <<include>>
        (Delete Student Information) ..> (Notify Students) : <<include>>
        (Generate Student Attendance Reports) ..> (Notify Students) : <<include>>
        (Generate Student Performance Reports) ..> (Notify Students) : <<include>>
        (Generate Enrollment Reports) ..> (Notify Students): <<include>>

        T -- (View Exams Information)
        (View Exams Information) <.. (Create Exams) : <<extend>>
        (View Exams Information) <.. (Update Exams) : <<extend>>
        (View Exams Information) <.. (Delete Exams) : <<extend>>
        (View Exams Information) <.. (View Exam Results) : <<extend>>
        (View Exams Information) <.. (Add Exam Results) : <<extend>>
        (View Exams Information) <.. (Update Exam Results) : <<extend>>
        (View Exams Information) <.. (Delete Exam Results) : <<extend>>

        (Create Exams) ..> (Notify Students): <<include>>
        (Update Exams) ..> (Notify Students): <<include>>
        (Delete Exams) ..> (Notify Students): <<include>>
        (Add Exam Results) ..> (Notify Students): <<include>>
        (Update Exam Results) ..> (Notify Students): <<include>>
        
        T -- (View Query Information)
        (View Query Information) <.. (View Queries) : <<extend>>
        (View Query Information) <.. (Feedback Queries) : <<extend>>
        (View Query Information) <.. (Submit Queries) : <<extend>>
        (View Query Information) <.. (Submit Leaves and Short Leaves) : <<extend>>

        (Feedback Student Queries) ..> (Notify Students): <<include>>
        (Submit Queries) ..> (Notify Students) : <<include>>
        (Submit Leaves and Short Leaves) ..> (Notify Sectional Heads) : <<include>>
        
        (Update Financial Information) -- TR
        (Update Logs) -- TR
        (Notify Teachers) -- TR
        (Inform Teachers) -- TR2

        S -- (View Query Information as a Student)
        (View Query Information as a Student) <.. (Submit Queries as a Student) : <<extend>>
        (View Query Information as a Student) <.. (Submit Queries as a Parent) : <<extend>>

        (Submit Queries as a Student) ..> (Notify Teachers) : <<include>>
        (Submit Queries as a Parent) ..> (Notify Teachers) : <<include>>

        S -- (View Educational Information as a Student)
        (View Educational Information as a Student) <.. (View Educational Content) : <<extend>>
        (View Educational Information as a Student) <.. (View Assessments) : <<extend>>
        (View Educational Information as a Student) <.. (Submit Assessments) : <<extend>>
        (View Educational Information as a Student) <.. (Update Assessments) : <<extend>>
        (View Educational Information as a Student) <.. (View Time Tables) : <<extend>>

        (Submit Assessments) ..> (Notify Teachers): <<include>>
        (Update Assessments) ..> (Notify Teachers): <<include>>

        S -- (View Extracurricular Information as a Student)
        (View Extracurricular Information as a Student) <.. (Apply for Societies and Clubs) : <<extend>>
        (View Extracurricular Information as a Student) <.. (Apply for Competitions) : <<extend>>

        (Apply for Societies and Clubs) ..> (Notify Teachers): <<include>>
        (Apply for Competitions) ..> (Notify Teachers): <<include>>

        S -- (View Exams Information as a Student)
        (View Exams Information as a Student) <.. (View Exams as a Student) : <<extend>>
        (View Exams Information as a Student) <.. (View Exam Results as a Student) : <<extend>>

        S -- (View Payment Information)
        (View Payment Information) <.. (Pay School Fees) : <<extend>>
        (View Payment Information) <.. (Pay Welfare Fees) : <<extend>>
        (View Payment Information) <.. (Donate to the School) : <<extend>>

        (Pay School Fees) ..> (Update Financial Information) : <<include>>
        (Pay Welfare Fees) ..> (Update Financial Information) : <<include>>
        (Donate to the School) ..> (Update Financial Information) : <<include>>
        
        (Notify Students) -- SR

        U -- (Enter the Attendance Daily)
        (Enter the Attendance Daily) ..> (Verify Using Fingerprint) : <<include>>

        U -- (Login)
        (Login) ..> (Validate User) : <<include>>
        (Validate User)..> (Update Logs) : <<include>>


        U -- (View User Profile)
        (View User Profile) <.. (View Profile Information) : <<extend>>
        (View User Profile) <.. (Update User Profile) : <<extend>>

        U -- (Comminication)
        (Comminication) <.. (Send Messages) : <<extend>>

        (Send Messages) ..> (Notify Users) : <<include>>

        U -- (Logout)
        (Logout) ..> (Confirm) : <<include>>

        (Notify Users) -- UR
}

@enduml