@startuml School Management System

left to right direction
skinparam linetype polyline

actor "Teacher" as T
actor "Teacher" as TR
actor "Class Teacher" as CT
actor "Class Teacher" as CTR
actor "Sectional Head" as SH
actor "Sectional Head" as SHR
actor "Treasurer" as TS
actor "Treasurer" as TSR
actor "Student" as S
actor "Student" as SR
actor "Prefect" as SP
actor "Prefect" as SPR
actor "Principal" as P
actor "Principal" as PR
actor "Vice Principal" as VP
actor "Vice Principal" as VPR
actor "Administrator" as A
actor "Administrator" as AR
actor "User" as U
actor "User" as UR

U <|-- T
U <|-- S
U <|-- VP
T <|-- CT
T <|-- SH
T <|-- TS
S <|-- SP
VP <|-- P
VP <|-- A

rectangle "School Management System" {
    rectangle "User" {
        U -- (Enter the Attendance Daily)
        U -- (Login)
        U -- (Communicate with Users)
        U -- (Logout)

        (Enter the Attendance Daily) ..> (Verify Using Fingerprint) : <<include>>
        (Login) ..> (Validate User) : <<include>>
    }

    rectangle "Teachers" {
        T -- (View Educational Content Dashboard)
        T -- (Provide Feedback and Assessments)
        T -- (Submit Leave and Short Leaves)
        T -- (View Student Information as a Teacher)

        (View Educational Content Dashboard) <.. (View Student Activity) : <<extend>>
        (View Educational Content Dashboard) <.. (Grade Student Activity) : <<extend>>
        (View Educational Content Dashboard) <.. (Create Educational Content) : <<extend>>
        (View Educational Content Dashboard) <.. (Update Educational Content) : <<extend>>
        (View Educational Content Dashboard) <.. (Delete Educational Content) : <<extend>>
        (Provide Feedback and Assessments) ..> (Inform Students) : <<include>>
        (Submit Leave and Short Leaves) ..> (Verify Leave) : <<include>>
        (View Student Information as a Teacher) <.. (Update Student Information) : <<extend>>
        (View Student Information as a Teacher) <.. (Delete Student Information) : <<extend>>
        (View Student Information as a Teacher) <.. (Create Student Information) : <<extend>>
        (View Student Information as a Teacher) <.. (Monitor Student Progress and Performance) : <<extend>>

        CT -- (Monitor Students Attendance)
        CT -- (View Exam Results)
        CT -- (Generate Student Reports)

        (Monitor Students Attendance) <.. (Notify Student) : <<extend>>
        (View Exam Results) <.. (Enter Exam Results) : <<extend>>
        (View Exam Results) <.. (Update Exam Results) : <<extend>>
        (View Exam Results) <.. (Remove Exam Results) : <<extend>>
        (View Exam Results) <.. (Sort Student Marks) : <<extend>>
        (Generate Student Reports) ..> (Inform Class Students) : <<include>>

        SH -- (Schedule Sectional Staff Meetings)
        SH -- (Create Sectional Events)
        (Verify Leave) -- SHR

        (Schedule Sectional Staff Meetings) ..> (Inform Sectional Teachers) : <<include>>
        (Create Sectional Events) ..> (Inform Sectional Teachers) : <<include>>
        (Create Sectional Events) ..> (Inform Sectional Students) : <<include>>
        
        TS -- (View School Financial Status)
        TS -- (Withdraw Funds from School Account)
        TS -- (Deposit Funds to School Account)
        TS -- (Monitor Student Payments)

        (View School Financial Status) <.. (Generate Financial Reports) : <<extend>>
        (View School Financial Status) <.. (Calculate School Budget) : <<extend>>
        (View School Financial Status) <.. (Monitor Student Payment) : <<extend>>
        (Monitor Student Payments) <.. (Notify Students) : <<extend>>
        (Withdraw Funds from School Account) ..> (Request Principal Permission) : <<include>>
        (Withdraw Funds from School Account) ..> (Update Logs) : <<include>>
        (Deposit Funds to School Account) ..> (Update Logs) : <<include>>
    }

    rectangle "Students" {
        S -- (View Educational Content Dashboard as a Student)
        S -- (Submit Assignments and Assessments)
        S -- (Pay School Fees and Other Welfare Fees)
        S -- (Submit Medicals for Sudden Leaves)
        S -- (Enter Extracurricular Activity Information)
        S -- (Create School Societies and Clubs)
        (Create Educational Content) -- SR
        (Update Educational Content) -- SR
        (Delete Educational Content) -- SR
        (Inform Students) -- SR
        (Inform Class Students) -- SR
        (Inform Sectional Students) -- SR
        (Inform Students as a Prefect) -- SR
        (Notify Students) -- SR
        (Notify Student) -- SR
        (Enter Exam Results) -- SR
        (Update Exam Results) -- SR
        (Grade Student Activity) -- SR

        (View Educational Content Dashboard as a Student) <.. (View Assessments) : <<extend>>
        (View Educational Content Dashboard as a Student) <.. (Upload Assessments) : <<extend>>
        (View Educational Content Dashboard as a Student) <.. (Update Assessments) : <<extend>>
        (Submit Assignments and Assessments) ..> (Inform Subject Teachers) : <<include>>
        (Pay School Fees and Other Welfare Fees) ..> (Generate Receipts) : <<include>>
        (Submit Medicals for Sudden Leaves) ..> (Verify Medical Information) : <<include>>
        (Enter Extracurricular Activity Information) <.. (Update Information) : <<extend>>
        (Create School Societies and Clubs) <.. (Add Members) : <<extend>>
        (Create School Societies and Clubs) <.. (Remove Members) : <<extend>>
        (Create School Societies and Clubs) <.. (Update Members) : <<extend>>

        SP -- (Enter Student Information as a Prefect)
        SP -- (Create Events for Students)
        SP -- (Delete Events for Students)
        SP -- (Update Events for Students)

        (Enter Student Information as a Prefect) <.. (Update Student Information as a Prefect)
        (Create Events for Students) ..> (Inform Students as a Prefect) : <<include>>
        (Delete Events for Students) ..> (Inform Students as a Prefect) : <<include>>
        (Update Events for Students) ..> (Inform Students as a Prefect) : <<include>>
    }  

    rectangle "Management" {
        VP -- (View Staff Members)
        VP -- (View Student Enrollment)
        VP -- (View Administrative Tasks)
        (Generate Financial Reports) -- VPR
        (Calculate School Budget) -- VPR

        (View Staff Members) <.. (Schedule Staff Meetings) : <<extend>>
        (View Staff Members) <.. (Add Staff Members) : <<extend>>
        (View Staff Members) <.. (Remove Staff Members) : <<extend>>
        (View Staff Members) <.. (Update Staff Members) : <<extend>>
        (View Student Enrollment) <.. (Review Enrollment Data) : <<extend>>
        (View Student Enrollment) <.. (Generate Enrollment Reports) : <<extend>>
        (View Administrative Tasks) <.. (Edit Administrative Tasks) : <<extend>>
        (View Administrative Tasks) <.. (Update Administrative Tasks) : <<extend>>
        (View Administrative Tasks) <.. (Delete Administrative Tasks) : <<extend>>
        (View Administrative Tasks) <.. (Create Administrative Tasks) : <<extend>>
        (Generate Financial Reports) -- VPR
        (Calculate School Budget) -- VPR

        P -- (Generate Reports)
        P -- (Create Special School Events)
        P -- (Send Notifications to Teachers)

        (Generate Reports) <.. (User Engagement Reports) : <<extend>>
        (Generate Reports) <.. (Performance Reports) : <<extend>>
        (Generate Reports) <.. (System Utilization Reports) : <<extend>>
        (Generate Reports) <.. (Content Popularity Reports) : <<extend>>
        (Generate Reports) <.. (Monthly Attendance Reports) : <<extend>>
        (Create Special School Events) ..> (Inform Teachers as the Principal) : <<include>>
        (Create Special School Events) ..> (Inform Students as the Principal) : <<include>>
        (Request Principal Permission) -- PR

        A -- (Create User Accounts and Access Permissions)
        A -- (Oversee Overall Functionality and Performance)
        A -- (Ensure Security and Integrity of the Platform)
        (Update Logs) -- AR

        (Create User Accounts and Access Permissions) <.. (Add User) : <<extend>>
        (Create User Accounts and Access Permissions) <.. (Delete User) : <<extend>>
        (Create User Accounts and Access Permissions) <.. (Modify Permissions) : <<extend>>
        (Oversee Overall Functionality and Performance) ..> (Oversee School Management) : <<include>>
        (Ensure Security and Integrity of the Platform) <.. (Encrypt Data) : <<extend>>
        (Ensure Security and Integrity of the Platform) <.. (Regular Data Backups) : <<extend>>
    }
}

@enduml