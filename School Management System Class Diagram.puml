@startuml School Management System

skinparam Linetype ortho

interface SchoolSystem {
  name: String
  date: Date
}

class User {
  - userType: String
  - userID: String
  - username: String
  - password: String
  - email: String
  - firstName: String
  - lastName: String
  - dateOfBirth: Date
  - fingerprint: String
  + enterAttendence()
  + login()
  + viewProfile()
  + updateProfile()
  + logout()
}

class Student {
  - studentID: String
  - gradeLevel: int
  - studentReport: Report
  + getStudentID()
  + getGradeLevel()
  + setGradeLevel()
  + getReport()
  + createReport()
  + updateReport()
}

class Teacher {
  - teacherID: String
  - subjectTaught: String
  - class: String
  - society: String
  - club: String
  + getTeacherID()
  + getSubjectTaught()
  + setSubjectTaught()
  + getClass()
  + setClass()
  + updateClass()
}

class SectionalHead {
  - section: String
  + getSection()
  + setSection()
  + informTeachers()
  + informStudents()
  + viewStudents()
  + addStudents()
  + updateStudents()
  + deleteStudents()
  + createClass()
  + deleteClass()
}

class VicePrincipal {
  + role: String
  + informPrincipal()
  + viewTeachers()
  + addTeachers()
  + updateTeachers()
  + deleteTeachers()
  + informSectionalHead()
  + viewEvents()
  + createEvents()
  + DeleteEvents()
}

class Principal {
  + broadcastAnnouncements()
  + informUsers()
  + informVicePrincipals()
  + viewAdministrativeInformation()
  + viewFinancialInformation()
  + addPolicy()
  + deletePolicy()
}

class Admin {
  + viewSystemDatabase()
  + createRecords()
  + editRecords()
  + deleteRecords()
  + viewUserInformation()
  + addUser()
  + updateUser()
  + deleteUser()
  + modifyPermissions()
  + viewSystemMonitor()
  + viewBackups()
  + regularInformationBackups()
  + generateSystemReports()
}

class Payment {
  - paymentId: int
  - amount: double
  - description: string
  - paymentDate: date
  - paymentMethod: string
  - status: string
  + paySchoolFees()
  + payWelfareFees()
  + donateSchool()
}

class Query {
  - queryId: int
  - userId: int
  - description: string
  - submissionDate: date
  - response: string
  - responseDate: date
}

class UserLog {
  - logId: int
  - userId: int
  - action: string
  - timestamp: datetime
  + addUserLog()
  + updateUserLog()
  + deleteUserLog()
  + getLogsByUser()
  + getLogsByAction()
  + getLogsByTimestamp()
}

class Policy {
  - policyId: int
  - policyName: string
  - description: string
  + updatePolicy()
  + getPolicyById()
  + getPolicyByName()
}

class FinancialInformation {
  - schoolBudget: double
  - income: double
  - expense: double
  - donations: double
  - studentPayments: List<Payment>
}

class EducationalInformation {
  - societies: List<Society>
  - assessments: List<Assessment>
  - competitions: List<Competition>
  + viewSocieties()
  + applyForSociety()
  + createSociety()
  + deleteSociety()
  + viewAssessments()
  + submitAssessment()
  + gradeAssessment()
  + viewContent()
  + createAssessment()
  + updateAssessment()
  + deleteAssessment()
  + viewCompetitions()
  + applyForCompetition()
  + createCompetition()
  + deleteCompetition()
}

class ExtracurricularInformation {
  - clubs: List<SocietyOrClub>
  - competitions: List<Competition>
  + viewContent()
  + viewClubs()
  + applyForClub()
  + createClub()
  + deleteClub()
  + viewCompetitions()
  + applyForCompetition()
  + createCompetition()
  + deleteCompetition()
}

class ExamInformation {
  - exams: List<Exam>
  + viewExams()
  + createExam()
  + updateExam()
  + deleteExam()
  + enterExamResults()
  + deleteExamResults()
  + applyForRecorrection()
}

class Assessment {
  - id: String
  - title: String
  - description: String
  - dueDate: Date
  - maxPoints: int
  - studentSubmissions: Map<Student, Submission>
  - grade: Grade
  + submitSubmission()
  + updateSubmission()
  + removeSubmission()
}

class Society {
  - id: String
  - name: String
  - description: String
  - members: List<Member>
  + addMember()
  + removeMember()
}

class Club {
  - id: String
  - name: String
  - description: String
  - members: List<Member>
  + addMember()
  + removeMember()
}

class Competition {
  - id: String
  - name: String
  - description: String
  - startDate: Date
  - endDate: Date
  - participants: List<Student>
  + enrollParticipant()
  + withdrawParticipant()
}

class Event {
  - eventId: int
  - eventName: string
  - eventDate: date
  - location: string
  - description: string
  + updateEvent()
}

class Exam {
  - id: String
  - name: String
  - description: String
  - date: Date
  - duration: int
  - results: Map<Student, Result>
  + enterResult()
  + deleteResult()
}

class Result {
  - score: int
  - grade: String
}

class Submission {
  - content: String
  - submissionDate: Date
}

class ClubMember {
  - id: String
  - name: String
  - role: String
}

class SocietyMember {
  - id: String
  - name: String
  - role: String
}

class Grade {
  - classes: List<Class>
  - students: List<Student>
  - studentCount: int
  - subjects: List<Subject>
  - teachers: List<Teacher>
}

class Class {
  - teacher: Teacher
  - students: List<Student>
  - studentCount: int
  - timeTable: TimeTable
}

class Announcement {
  - header: String
  - content: String
  - userTypes: String
}

abstract class Report {
  - dateCreated: Date
  - dateModified: Date
  - generatedBy: String
}

class StudentReport {
  - studentPerformance: String
  - studentAttendence: String
  - studentLetters: String
  - studentAchivements: String
  - studentHealthStatus: String
}

class SystemReport {
  - systemUtilization: int
  - systemLogs : List<SystemLog>
  - errors: String
}

SchoolSystem "1" *-- "*" User : Has
SchoolSystem "1" *-- "1" EducationalInformation : Has
SchoolSystem "1" *-- "1" ExtracurricularInformation : Has
SchoolSystem "1" *-- "1" FinancialInformation : Has
SchoolSystem "1" *-- "0..*" Report : Has

Grade "1" *-- "1..*" Class : Has
Grade "1" *-- "1..*" Teacher : Has
Grade "1" *-- "1" SectionalHead : Has
Class "1" *-- "1" Teacher : Has
Class "1" *-- "1..*" Student : Has

User <|-- Student
User <|-- Teacher
User <|-- VicePrincipal
VicePrincipal <|-- Principal
VicePrincipal -- Event
Principal <|-- Admin

Student "1..*" -- "1..*" SectionalHead : Manage
Teacher "1..*" -- "1..*" VicePrincipal : Manage

Report <|-- StudentReport
Report <|-- SystemReport

Admin "1" -- "0..*" SystemReport : Generate
Admin "1" -- "0..*" UserLog : View
Principal "1" -- "0..*" Policy : Manage
Principal "1" -- "0..*" Announcement : Manage
VicePrincipal "1" -- "1" FinancialInformation : Manage
SectionalHead "1" -- "1" Grade : Manage
Teacher "1" -- "1" ExtracurricularInformation : Manage
Teacher "1" -- "1" EducationalInformation : Manage
Teacher "1" -- "0..*" Query : Manage
Teacher "1" -- "0..*" StudentReport : Manage
Student "1" -- "1" EducationalInformation : View
Student "1" -- "1" ExtracurricularInformation : View
Student "1" -- "0..*" Query : Submit
Student "1" -- "0..*" Payment : Make
User "1" -- "0..*" Event : View
User "1" -- "0..*" Announcement : View
Student "1" *-- "1" StudentReport : Has
Exam "1" O-- "0..*" Result : Has
Society "1" *-- "1..*" SocietyMember : Has
Club "1" *-- "1..*" ClubMember : Has
User "1" *-- "1" UserLog : Has

FinancialInformation "1" o-- "0..*" Payment : Has
EducationalInformation "1" o-- "0..*" ExamInformation : Has
EducationalInformation "1" o-- "0..*" Society : Has
EducationalInformation "1" o-- "0..*" Competition : Has
EducationalInformation "1" o-- "0..*" Assessment : Has
ExamInformation "1" o-- "0..*" Exam : Has
Assessment "1" o-- "1" Submission : Has
ExtracurricularInformation "1" o-- "0..*" Competition : Has
ExtracurricularInformation "1" o-- "0..*" Club : Has

@enduml