@startuml School Management System

class User {
  - userType: String
  - userID: String
  - username: String
  - password: String
  - email: String
  - firstName: String
  - lastName: String
  - dateOfBirth: Date
  - fingerprint: String
  + enterAttendence()
  + login()
  + viewProfile()
  + updateProfile()
  + logout()
}

class Student {
  - studentID: String
  - gradeLevel: int
  - studentReport: Report
  + getStudentID()
  + getGradeLevel()
  + setGradeLevel()
  + getReport()
  + createReport()
  + updateReport()
}

class Teacher {
  - teacherID: String
  - subjectTaught: String
  - class: String
  - society: String
  - club: String
  + getTeacherID()
  + getSubjectTaught()
  + setSubjectTaught()
  + getClass()
  + setClass()
  + updateClass()
}

class SectionalHead {
  - section: String
  + getSection()
  + setSection()
  + informTeachers()
  + informStudents()
  + viewStudents()
  + addStudents()
  + updateStudents()
  + deleteStudents()
  + createClass()
  + deleteClass()
}

class VicePrincipal {
  + role: String
  + informPrincipal()
  + viewTeachers()
  + addTeachers()
  + updateTeachers()
  + deleteTeachers()
  + informSectionalHead()
}

class Principal {
  + broadcastAnnouncements()
  + informUsers()
  + informVicePrincipals()
  + viewAdministrativeInformation()
  + viewFinancialInformation()
}

class Admin {
  + viewSystemDatabase()
  + createRecords()
  + editRecords()
  + deleteRecords()
  + viewUserInformation()
  + addUser()
  + updateUser()
  + deleteUser()
  + modifyPermissions()
  + viewSystemMonitor()
  + viewBackups()
  + regularInformationBackups()
  + generateSystemReports()
}

class Payment {
  - paymentId: int
  - amount: double
  - description: string
  - paymentDate: date
  - paymentMethod: string
  - status: string
}

class Query {
  - queryId: int
  - userId: int
  - description: string
  - submissionDate: date
  - response: string
  - responseDate: date
}

class Event {
  - eventId: int
  - eventName: string
  - eventDate: date
  - location: string
  - description: string
  + viewEvents()
  + createEvents()
  + UpdateEvents()
  + DeleteEvents()
}

class UserLog {
  - logId: int
  - userId: int
  - action: string
  - timestamp: datetime
  + addUserLog()
  + updateUserLog()
  + deleteUserLog()
  + getLogsByUser()
  + getLogsByAction()
  + getLogsByTimestamp()
}

class Policy {
  - policyId: int
  - policyName: string
  - description: string
  + addPolicy()
  + updatePolicy()
  + deletePolicy()
  + getPolicyById()
  + getPolicyByName()
}

class EducationalInformation {
  - assessments: List<Assessment>
  - Content: List<Conntent>
  + viewAssessments()
  + submitAssessment()
  + gradeAssessment()
  + viewContent()
}

class ExtracurricularInformation {
  - societiesAndClubs: List<SocietyOrClub>
  - competitions: List<Competition>
  - events: List<Event>
  + viewSocietiesAndClubs()
  + applyForSocietyOrClub()
  + createSocietyOrClub()
  + deleteSocietyOrClub()
  + viewCompetitions()
  + applyForCompetition()
  + createCompetition()
  + deleteCompetition()
  + viewEvents()
  + applyForEvent()
}

class ExamInformation {
  - exams: List<Exam>
  + viewExams(): List<Exam>
  + createExam()
  + updateExam()
  + deleteExam()
  + enterExamResults()
  + deleteExamResults()
  + applyForRecorrection()
}

class Assessment {
  - id: String
  - title: String
  - description: String
  - dueDate: Date
  - maxPoints: int
  - studentSubmissions: Map<Student, Submission>
  - grade: Grade
  + createAssessment()
  + updateAssessment()
  + deleteAssessment()
  + submitSubmission()
  + getSubmission()
}

class SocietyOrClub {
  - id: String
  - name: String
  - description: String
  - members: List<Member>
  + addMember()
  + removeMember()
}

class Competition {
  - id: String
  - name: String
  - description: String
  - startDate: Date
  - endDate: Date
  - participants: List<Student>
  + enrollParticipant()
  + withdrawParticipant()
}

class Event {
  - id: String
  - name: String
  - description: String
  - date: Date
}

class Exam {
  - id: String
  - name: String
  - description: String
  - date: Date
  - duration: int
  - results: Map<Student, Result>
  + enterResult()
  + deleteResult()
}

class Result {
  - score: int
  - grade: String
}

class Submission {
  - content: String
  - submissionDate: Date
  + Submit()
  + removeSubmission()
}

class Member {
  - id: String
  - name: String
  - role: String
}

class Grade {
  - classes: List<Class>
  - students: List<Student>
  - studentCount: int
  - subjects: List<Subject>
  - teachers: List<Teacher>
}

class Class {
  - teacher: Teacher
  - students: List<Student>
  - studentCount: int
  - timeTable: TimeTable
}

class Announcement {
  - header: String
  - content: String
  - userTypes: String
}

abstract class Report {
  - dateCreated: Date
  - dateModified: Date
  - generatedBy: String
}

class StudentReport {
  - studentPerformance: String
  - studentAttendence: String
  - studentLetters: String
  - studentAchivements: String
  - studentHealthStatus: String
}

class SystemReport {
  - systemUtilization: int
  - systemLogs : List<SystemLog>
  - errors: String
}

User <|-- Student
User <|-- Teacher
User <|-- VicePrincipal
Teacher <|-- SectionalHead
VicePrincipal <|-- Principal
VicePrincipal -- Event
Principal <|-- Admin

Report <|-- StudentReport
Report <|-- SystemReport

SystemReport -- Admin
SocietyOrClub "1" *-- "0..*" Member
EducationalInformation -- Exam
Exam "1" *-- "0..*" Result
User -- Event
User -- Announcement
Principal -- Policy
Principal -- Announcement
Teacher -- ExtracurricularInformation
Teacher -- EducationalInformation
Teacher -- Query
Student -- EducationalInformation
Student -- ExtracurricularInformation
Student -- Query
Student -- Payment
Student -- StudentReport
Student -- Submission
Submission -- Assessment

User *-- UserLog
Grade *-- Class
Class *-- Teacher
Class *-- Student

EducationalInformation -- Competition
EducationalInformation -- ExamInformation
ExtracurricularInformation -- Competition
ExtracurricularInformation -- SocietyOrClub

@enduml