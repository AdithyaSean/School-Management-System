@startuml School Management System
class User {
  - id: int
  - name: string
  - role: string
}

class Student {
  - grade: int
  - attendance: List<AttendanceRecord>
}

Student --|> User

class Teacher {
  - subject: string
}

Teacher --|> User

class Course {
  - name: string
  - teacher: Teacher
  - students: List<Student>
}

class EducationalContent {
  - title: string
  - content: string
  - course: Course
}

Course *-- EducationalContent

class AttendanceRecord {
  - date: Date
  - status: string
}

Student *-- AttendanceRecord
@enduml
