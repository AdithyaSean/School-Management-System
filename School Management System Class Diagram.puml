@startuml School Management System
skinparam linetype polyline

class User {
  + username: String
  + password: String
  + fingerprint: String

  + login()
  + logout()
  + viewProfile()
  + updateProfile()
}

class Student extends User {
  + gradeLevel: String

  + viewPaymentInformation()
  + paySchoolFees()
  + payWelfareFees()
  + donateToSchool()
  + viewQueryInformation()
  + submitQuery()
  + viewEducationalInformation()
  + submitAssessments()
  + completeTasks()
  + viewExtracurricularInformation()
  + applyForSocietiesAndClubs()
  + applyForCompetitions()
  + viewExamsInformation()
  + applyForRecorrections()
}

class Teacher extends Student {
  + subject: String

  + viewStudentInformation()
  + createStudentInformation()
  + updateStudentInformation()
  + deleteStudentInformation()
  + generateStudentReports()
  + viewEducationalInformation()
  + gradeStudentAssessments()
  + sendFeedbackAndAssessments()
  + createEducationalContent()
  + editEducationalContent()
  + deleteEducationalContent()
  + viewExtracurricularInformation()
  + addMembers()
  + removeMembers()
  + updateMembers()
  + createCompetitions()
  + createSocietiesAndClubs()
  + deleteSocietiesAndClubs()
  + updateSocietiesAndClubs()
  + viewExamInformation()
  + createExams()
  + updateExams()
  + deleteExams()
  + enterExamResults()
  + deleteExamResults()
  + viewQueryInformation()
  + provideFeedback()
}

class SectionalHead extends Teacher {
  + section: String
  + ... (other attributes)

  + viewStaffInformation()
  + addStaffMembers()
  + updateStaffMembers()
  + removeStaffMembers()
  + createTimeTables()
  + updateTimeTables()
  + deleteTimeTables()
  + scheduleMeetings()
}

class VicePrincipal extends SectionalHead {
  + ... (other attributes)

  + viewEventsInformation()
  + createEvents()
  + editEvents()
  + deleteEvents()
  + viewAdministrativeInformation()
  + updateAdministrativeInformation()
  + viewFinancialInformation()
  + planSchoolBudget()
  + updateSchoolBudget()
  + generateFinancialReports()
  + withdrawFunds()
  + depositFunds()
}

class Principal extends VicePrincipal {
  + ... (other attributes)

  + broadcastAnnouncements()
  + viewAdministrativeInformation()
  + createPolicies()
  + editPolicies()
  + deletePolicies()
  + viewFinancialInformation()
  + planSchoolBudget()
  + updateSchoolBudget()
  + generateFinancialReports()
  + withdrawFunds()
  + depositFunds()
}

class Administrator extends Principal {
  + viewSystemDatabase()
  + createUser()
  + updateUser()
  + deleteUser()
  + modifyPermissions()
  + viewUserInformation()
  + viewSystemMonitor()
  + generateReports()
  + viewBackups()
  + performBackups()
}

@enduml