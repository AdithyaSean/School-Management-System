@startuml School Management System

class User {
    +username: String
    +password: String
    +login()
    +logout()
}

class Teacher {
    +accessEducationalContentDashboard()
    +accessExtracurricularContentDashboard()
    +accessStudentsManagementDashboard()
    +accessExamDashboard()
    +accessQueryDashboard()
}

class ClassTeacher {
    +generateStudentReports()
    +sendNotificationsToClassTeachers()
}

class SectionalHead {
    +accessExamDashboard()
    +accessStaffManagementDashboardAsTeacher()
    +sendNotificationsToSectionalHead()
}

class Student {
    +accessEducationalContentDashboard()
    +accessExtracurricularContentDashboard()
    +accessExamDashboard()
    +accessPaymentDashboard()
    +accessQueryDashboardAsStudent()
}

class Principal {
    +accessExamDashboard()
    +accessQueryDashboard()
    +accessAdministrativeDashboard()
}

class VicePrincipal {
    +broadcastAnnouncements()
    +accessEventManagementDashboard()
    +accessStaffManagementDashboard()
    +accessStudentManagementDashboard()
    +accessFinancialManagementDashboard()
}

class Administrator {
    +createUserAccountsAndAccessPermissions()
    +overseeOverallFunctionalityAndPerformance()
    +ensureSecurityAndIntegrityOfThePlatform()
    +generateReports()
}

User <|-- Teacher
User <|-- Student
User <|-- VicePrincipal
User <|-- Administrator
Teacher <|-- ClassTeacher
Teacher <|-- SectionalHead
Student <|-- ClassTeacher
Student <|-- VicePrincipal
Student <|-- Administrator
Principal <|-- VicePrincipal

@enduml
