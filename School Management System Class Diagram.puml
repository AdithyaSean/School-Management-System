@startuml SchoolManagementSystem

class User {
  + username: String
  + password: String
  + role: String (e.g., Teacher, Student, Admin)
  + login()
  + logout()
}

abstract class Actor {
  + interact(system: System)
}

class Teacher extends Actor {
  // Specific functionalities for Teacher
}

class Student extends Actor {
  // Specific functionalities for Student
}

class Administrator extends Actor {
  // Specific functionalities for Administrator
}

class SchoolManagementSystem {
  + users: List<User>
  + sendNotifications(message: String, recipients: List<User>)
  // Methods for various functionalities based on use cases (e.g., createExam(), viewStudentPerformance())
}

U <|-- User
Teacher <|-- Actor
Student <|-- Actor
Administrator <|-- Actor

System --> SchoolManagementSystem

@enduml