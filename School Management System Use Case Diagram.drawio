        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml School Management System\n\nleft to right direction\nskinparam linetype polyline\n\nactor \&quot;Teacher\&quot; as T\nactor \&quot;Class Teacher\&quot; as CT\nactor \&quot;Sectional Head\&quot; as SH\nactor \&quot;Treasurer\&quot; as TR\nactor \&quot;Student\&quot; as S\nactor \&quot;Prefect\&quot; as SP\nactor \&quot;Principal\&quot; as P\nactor \&quot;Vice Principal\&quot; as VP\nactor \&quot;Administrator\&quot; as A\nactor \&quot;User\&quot; as U\n\nU &lt;|-- T\nU &lt;|-- S\nU &lt;|-- VP\nT &lt;|-- CT\nT &lt;|-- SH\nT &lt;|-- TR\nS &lt;|-- SP\nVP &lt;|-- P\nVP &lt;|-- A\n\nrectangle \&quot;School Management System\&quot; {\n    rectangle \&quot;User\&quot; {\n        U -- (Enter the Attendance Daily)\n        U -- (Login)\n        U -- (Communicate with Users)\n        U -- (Logout)\n\n        (Enter the Attendance Daily) ..&gt; (Verify Using Fingerprint) : &lt;&lt;include&gt;&gt;\n        (Login) ..&gt; (Validate User) : &lt;&lt;include&gt;&gt;\n    }\n\n    rectangle \&quot;Teachers\&quot; {\n        T -- (View Educational Content Dashboard)\n        T -- (Provide Feedback and Assessments)\n        T -- (Submit Leave and Short Leaves)\n        T -- (View Student Information as a Teacher)\n\n        (View Educational Content Dashboard) &lt;.. (Create Educational Content) : &lt;&lt;extend&gt;&gt;\n        (View Educational Content Dashboard) &lt;.. (Update Educational Content) : &lt;&lt;extend&gt;&gt;\n        (View Educational Content Dashboard) &lt;.. (Delete Educational Content) : &lt;&lt;extend&gt;&gt;\n        (Provide Feedback and Assessments) ..&gt; (Inform Students) : &lt;&lt;include&gt;&gt;\n        (Submit Leave and Short Leaves) ..&gt; (Verify Leave) : &lt;&lt;include&gt;&gt;\n        (View Student Information as a Teacher) &lt;.. (Update Student Information) : &lt;&lt;extend&gt;&gt;\n        (View Student Information as a Teacher) &lt;.. (Delete Student Information) 